# === Telegram ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
AUTHORIZED_CHAT_ID=your-numeric-user-id

# === Workdirs (comma-separated) ===
# WORKDIRS=/path/to/project1,/path/to/project2
# DEFAULT_WORKDIR_INDEX=0

# Legacy single workdir (fallback if WORKDIRS not set)
OPENCODE_WORKDIR=/workspace

# === CLI Backends ===
# Multiple CLIs can be configured with numbered prefix:
# CLI_1_NAME=opencode
# CLI_1_BIN=/path/to/opencode
# CLI_1_ARGS=run,--dir
#
# CLI_2_NAME=codex
# CLI_2_BIN=/path/to/codex
# CLI_2_ARGS=
#
# CLI_3_NAME=claude
# CLI_3_BIN=/path/to/claude
# CLI_3_ARGS=
#
# DEFAULT_CLI=opencode

# Legacy single CLI binary (fallback if no CLI_* vars set)
OPENCODE_BIN=opencode
